---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
const title='Page Not Found (404)';
const description='The page you were looking for could not be found.';
---
<BaseLayout title={title} description={description} path="/404/" noindex={true}>
  <div class="page-band"><div class="container"><h1>Page not found</h1><p class="intro">Sorry — we couldn't find the page you were looking for. It may have moved, or the link may be out of date.</p></div></div>
  <section class="section"><div class="container">
    <p style="margin-bottom:18px"><a class="btn btn-primary" href="/">Back to home</a></p>
    <div class="grid grid-3">
      <Card title="Tournament Calendar" href="/tournaments/" tag="Popular" body="The full 2026 Malaysian tennis calendar." />
      <Card title="Tennis Events Guide" href="/malaysia-tennis-events/" tag="Popular" body="Understand the events played across Malaysia." />
      <Card title="Tennis Rules" href="/tennis-rules/" tag="Popular" body="The basics of how tennis is played." />
    </div>
  </div></section>
</BaseLayout>
