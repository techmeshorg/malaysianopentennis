---
import { SITE } from '../data/site-nav.js';
const { items = [] } = Astro.props; // [{name, href}], last item is current page
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((it, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: it.name,
    item: new URL(it.href, SITE.url).href,
  })),
};
---
<nav class="crumbs" aria-label="Breadcrumb">
  <ol>
    {items.map((it, i) => (
      <li>
        {i < items.length - 1 ? <a href={it.href}>{it.name}</a> : <span aria-current="page">{it.name}</span>}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
